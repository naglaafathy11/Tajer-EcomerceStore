@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = Model.Name;
}

<style>

    body {
        background: #f4f7fb;
    }

    .details-header {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 24px;
        padding: 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 35px rgba(79,70,229,.25);
    }

        .details-header::before {
            content: "";
            position: absolute;
            width: 250px;
            height: 250px;
            background: rgba(255,255,255,.08);
            border-radius: 50%;
            top: -100px;
            right: -80px;
        }

    .glass-card {
        background: white;
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0,0,0,.06);
    }

    .section-title {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        padding: 15px 22px;
        font-weight: 600;
        font-size: 17px;
    }

    .product-image-box {
        background: linear-gradient(180deg, #ffffff, #eef2ff);
        min-height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
    }

        .product-image-box img {
            max-height: 340px;
            width: 100%;
            object-fit: contain;
            transition: .3s;
        }

            .product-image-box img:hover {
                transform: scale(1.04);
            }

    .info-badge {
        border-radius: 30px;
        padding: 10px 18px;
        font-weight: 600;
        font-size: 14px;
    }

    .stat-box {
        border-radius: 22px;
        padding: 22px;
        text-align: center;
        background: #f8fafc;
        transition: .3s;
        height: 100%;
    }

        .stat-box:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,.06);
        }

    .stat-icon {
        width: 55px;
        height: 55px;
        margin: auto;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
        font-size: 22px;
    }

    .info-row {
        background: #f8fafc;
        border-radius: 16px;
        padding: 15px 18px;
        margin-bottom: 14px;
    }

    .review-item {
        border: none;
        border-bottom: 1px solid #eef2f7;
        padding: 18px 22px;
    }

        .review-item:last-child {
            border-bottom: none;
        }

    .btn-gradient {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        color: white;
        padding: 12px 28px;
        border-radius: 14px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-gradient:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(124,58,237,.25);
        }

    .btn-soft {
        border-radius: 14px;
        padding: 12px 24px;
        font-weight: 600;
    }

    .description-box {
        background: #f8fafc;
        border-radius: 18px;
        padding: 20px;
        color: #475569;
        line-height: 1.8;
    }

    .empty-image {
        text-align: center;
        color: #94a3b8;
    }

        .empty-image i {
            font-size: 70px;
        }

</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="details-header mb-4">

        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

            <div class="d-flex align-items-center gap-3">

                <a asp-action="Index"
                   class="btn btn-light rounded-circle shadow-sm">
                    <i class="bi bi-arrow-left"></i>
                </a>

                <div>
                    <h2 class="fw-bold mb-1">@Model.Name</h2>

                    <div class="d-flex align-items-center gap-2 flex-wrap">

                        <span class="badge bg-light text-dark info-badge">
                            <i class="bi bi-tag me-1"></i>
                            @Model.CategoryName
                        </span>

                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success info-badge">
                                <i class="bi bi-check-circle me-1"></i>
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger info-badge">
                                <i class="bi bi-x-circle me-1"></i>
                                Inactive
                            </span>
                        }

                    </div>
                </div>

            </div>

            <div class="text-end">
                <div class="small opacity-75">Product ID</div>
                <div class="fw-bold fs-5">#@Model.Id</div>
            </div>

        </div>

    </div>

    <div class="row g-4">

        <!-- IMAGE -->
        <div class="col-lg-4">

            <div class="glass-card h-100">

                <div class="section-title">
                    <i class="bi bi-image me-2"></i>
                    Product Image
                </div>

                <div class="product-image-box">

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="empty-image">
                            <i class="bi bi-image"></i>
                            <p class="mt-3 mb-0">No Image Available</p>
                        </div>
                    }

                </div>

            </div>

        </div>

        <!-- DETAILS -->
        <div class="col-lg-8">

            <!-- DESCRIPTION -->
            <div class="glass-card mb-4">

                <div class="section-title">
                    <i class="bi bi-info-circle me-2"></i>
                    Product Information
                </div>

                <div class="p-4">

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="description-box mb-4">
                            @Model.Description
                        </div>
                    }

                    <div class="row g-4">

                        <!-- PRICE -->
                        <div class="col-md-4">

                            <div class="stat-box">

                                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                                    <i class="bi bi-cash-stack"></i>
                                </div>

                                <div class="small text-muted mb-2">
                                    Product Price
                                </div>

                                <div class="fw-bold fs-3 text-dark">
                                    @Model.Price.ToString("C")
                                </div>

                            </div>

                        </div>

                        <!-- DISCOUNT -->
                        <div class="col-md-4">

                            <div class="stat-box">

                                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                                    <i class="bi bi-percent"></i>
                                </div>

                                <div class="small text-muted mb-2">
                                    Discount Price
                                </div>

                                <div class="fw-bold fs-3 @(Model.DiscountPrice.HasValue ? "text-danger" : "text-muted")">

                                    @(Model.DiscountPrice.HasValue
                                        ? Model.DiscountPrice.Value.ToString("C")
                                        : "—")

                                </div>

                            </div>

                        </div>

                        <!-- STOCK -->
                        <div class="col-md-4">

                            <div class="stat-box">

                                <div class="stat-icon bg-success bg-opacity-10 text-success">
                                    <i class="bi bi-box-seam"></i>
                                </div>

                                <div class="small text-muted mb-2">
                                    Stock Quantity
                                </div>

                                <div class="fw-bold fs-3 @(Model.StockQuantity == 0 ? "text-danger" : "text-dark")">
                                    @Model.StockQuantity
                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- EXTRA INFO -->
            <div class="glass-card mb-4">

                <div class="section-title">
                    <i class="bi bi-clock-history me-2"></i>
                    Additional Information
                </div>

                <div class="p-4">

                    <div class="info-row d-flex justify-content-between align-items-center">
                        <span class="text-muted">
                            <i class="bi bi-calendar-plus me-2"></i>
                            Created At
                        </span>

                        <span class="fw-semibold">
                            @Model.AddedAt
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.UpdatedAt))
                    {
                        <div class="info-row d-flex justify-content-between align-items-center">
                            <span class="text-muted">
                                <i class="bi bi-pencil-square me-2"></i>
                                Last Updated
                            </span>

                            <span class="fw-semibold">
                                @Model.UpdatedAt
                            </span>
                        </div>
                    }

                    <div class="info-row d-flex justify-content-between align-items-center mb-0">
                        <span class="text-muted">
                            <i class="bi bi-chat-left-text me-2"></i>
                            Reviews Count
                        </span>

                        <span class="fw-semibold">
                            @Model.Reviews.Count review(s)
                        </span>
                    </div>

                </div>

            </div>

            <!-- REVIEWS -->
            @if (Model.Reviews.Any())
            {
                <div class="glass-card">

                    <div class="section-title">
                        <i class="bi bi-star-half me-2"></i>
                        Customer Reviews
                    </div>

                    <div class="list-group list-group-flush">

                        @foreach (var review in Model.Reviews)
                        {
                            <div class="review-item">

                                <div class="d-flex align-items-start gap-3">

                                    <div class="rounded-circle bg-warning bg-opacity-25
                                        text-warning d-flex align-items-center justify-content-center"
                                         style="width:45px;height:45px;">

                                        <i class="bi bi-chat-quote"></i>

                                    </div>

                                    <div class="text-muted">
                                        @review
                                    </div>

                                </div>

                            </div>
                        }

                    </div>

                </div>
            }

        </div>

    </div>

    <!-- ACTION BUTTONS -->
    <div class="glass-card mt-4 p-4">

        <div class="d-flex flex-wrap gap-3 align-items-center">

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-gradient">

                <i class="bi bi-pencil-square me-2"></i>
                Edit Product

            </a>

            <form asp-action="Toggle"
                  asp-route-id="@Model.Id"
                  method="post"
                  class="d-inline">

                @Html.AntiForgeryToken()

                <button type="submit"
                        class="btn @(Model.IsActive
                                                        ? "btn-outline-warning"
                                                        : "btn-outline-success")
                    btn-soft">

                    <i class="bi @(Model.IsActive
                                                   ? "bi-toggle-on"
                                                   : "bi-toggle-off") me-2"></i>

                    @(Model.IsActive
                        ? "Deactivate Product"
                        : "Activate Product")

                </button>

            </form>

            <a asp-action="Delete"
               asp-route-id="@Model.Id"
               class="btn btn-outline-danger btn-soft ms-auto">

                <i class="bi bi-trash me-2"></i>
                Delete Product

            </a>

        </div>

    </div>

</div>