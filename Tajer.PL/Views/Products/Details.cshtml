@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="fw-semibold mb-0">Product Details</h2>
</div>

<div class="row g-4">

    @* Image column *@
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex align-items-center justify-content-center p-3"
                 style="min-height:260px; background:#f8f9fa;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name"
                         class="img-fluid rounded" style="max-height:260px; object-fit:contain;" />
                }
                else
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-image fs-1 d-block mb-2"></i>
                        <small>No image</small>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Info column *@
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h4 class="fw-semibold mb-1">@Model.Name</h4>
                        <span class="badge bg-secondary bg-opacity-10 text-secondary">@Model.CategoryName</span>
                    </div>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success fs-6">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger fs-6">Inactive</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-3">@Model.Description</p>
                }

                <hr />

                <div class="row g-3">
                    <div class="col-sm-4">
                        <div class="p-3 rounded bg-light text-center">
                            <div class="small text-muted mb-1">Price</div>
                            <div class="fw-semibold fs-5">@Model.Price.ToString("C")</div>
                        </div>
                    </div>

                    <div class="col-sm-4">
                        <div class="p-3 rounded bg-light text-center">
                            <div class="small text-muted mb-1">Discount Price</div>
                            <div class="fw-semibold fs-5 @(Model.DiscountPrice.HasValue ? "text-danger" : "text-muted")">
                                @(Model.DiscountPrice.HasValue ? Model.DiscountPrice.Value.ToString("C") : "—")
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-4">
                        <div class="p-3 rounded bg-light text-center">
                            <div class="small text-muted mb-1">Stock</div>
                            <div class="fw-semibold fs-5 @(Model.StockQuantity == 0 ? "text-danger" : "")">
                                @Model.StockQuantity
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <dl class="row small mb-0">
                    <dt class="col-sm-4 text-muted fw-normal">Created</dt>
                    <dd class="col-sm-8">@Model.AddedAt</dd>

                    @if (!string.IsNullOrEmpty(Model.UpdatedAt))
                    {
                        <dt class="col-sm-4 text-muted fw-normal">Last Updated</dt>
                        <dd class="col-sm-8">@Model.UpdatedAt</dd>
                    }

                    <dt class="col-sm-4 text-muted fw-normal">Reviews</dt>
                    <dd class="col-sm-8">@Model.Reviews.Count review(s)</dd>
                </dl>

            </div>
        </div>

        @* Reviews *@
        @if (Model.Reviews.Any())
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white fw-medium py-3">
                    Reviews <span class="badge bg-secondary ms-1">@Model.Reviews.Count</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var review in Model.Reviews)
                    {
                        <li class="list-group-item small text-muted">
                            <i class="bi bi-chat-left-quote me-2"></i>@review
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@* Action buttons *@
<div class="d-flex gap-2 mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
        <i class="bi bi-pencil me-1"></i> Edit
    </a>

    <form asp-action="Toggle" asp-route-id="@Model.Id" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn @(Model.IsActive ? "btn-outline-warning" : "btn-outline-success")">
            <i class="bi @(Model.IsActive ? "bi-toggle-on" : "bi-toggle-off") me-1"></i>
            @(Model.IsActive ? "Deactivate" : "Activate")
        </button>
    </form>

    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger ms-auto">
        <i class="bi bi-trash me-1"></i> Delete
    </a>
</div>
