@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = "Add Product";
}

<style>
    body {
        background: #f4f7fb;
    }

    .page-title {
        font-weight: 700;
        color: #1e293b;
    }

    .main-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 10px 35px rgba(0,0,0,.07);
    }

    .section-header {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        padding: 14px 20px;
        font-size: 17px;
        font-weight: 600;
        letter-spacing: .3px;
    }

    .form-control,
    .form-select {
        border-radius: 14px;
        min-height: 48px;
        border: 1px solid #dbe2ea;
        transition: .2s ease;
    }

    textarea.form-control {
        min-height: 120px;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 .2rem rgba(99,102,241,.15);
    }

    .form-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
    }

    .input-group-text {
        border-radius: 14px 0 0 14px;
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #dbe2ea;
        font-weight: 600;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        color: white;
        border-radius: 14px;
        padding: 12px 30px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(124,58,237,.25);
            color: white;
        }

    .btn-cancel {
        border-radius: 14px;
        padding: 12px 30px;
        font-weight: 600;
    }

    .tips-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        background: linear-gradient(180deg, #ffffff, #eef2ff);
        box-shadow: 0 8px 25px rgba(0,0,0,.05);
        position: sticky;
        top: 20px;
    }

    .tips-header {
        background: linear-gradient(135deg, #f59e0b, #f97316);
        color: white;
        padding: 15px 20px;
        font-weight: 700;
    }

    .tip-item {
        display: flex;
        gap: 10px;
        margin-bottom: 16px;
        color: #475569;
    }

        .tip-item i {
            color: #7c3aed;
            margin-top: 3px;
        }

    .image-preview {
        display: none;
        margin-top: 20px;
        text-align: center;
    }

        .image-preview img {
            max-height: 220px;
            width: 100%;
            object-fit: contain;
            border-radius: 18px;
            border: 2px dashed #c7d2fe;
            padding: 10px;
            background: #f8fafc;
        }

    .section-body {
        padding: 25px;
    }

    .status-box {
        background: linear-gradient(135deg, #ecfeff, #f0fdf4);
        border-radius: 18px;
        padding: 18px;
    }

    .custom-switch .form-check-input {
        width: 3rem;
        height: 1.5rem;
    }

    .top-bar {
        background: white;
        border-radius: 18px;
        padding: 18px 22px;
        box-shadow: 0 5px 18px rgba(0,0,0,.05);
    }
</style>

<div class="container py-4">

    <div class="top-bar d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-light rounded-circle shadow-sm">
                <i class="bi bi-arrow-left"></i>
            </a>

            <div>
                <h2 class="page-title mb-0">Add New Product</h2>
                <small class="text-muted">Create and publish your product professionally</small>
            </div>
        </div>

        <div>
            <span class="badge bg-primary px-3 py-2 rounded-pill">
                <i class="bi bi-box-seam me-1"></i> Product Panel
            </span>
        </div>
    </div>

    <div class="row g-4">

        <!-- FORM -->
        <div class="col-lg-8">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="All"
                     class="alert alert-danger rounded-4 shadow-sm"></div>

                <!-- BASIC INFO -->
                <div class="main-card mb-4">

                    <div class="section-header">
                        <i class="bi bi-info-circle me-2"></i>
                        Basic Information
                    </div>

                    <div class="section-body">

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label"></label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Wireless Headphones" />

                            <span asp-validation-for="Name"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description"
                                   class="form-label"></label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      placeholder="Write a professional product description..."></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger small"></span>
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-4">
                                <label asp-for="CategoryId"
                                       class="form-label">
                                    Category
                                </label>

                                <select asp-for="CategoryId"
                                        asp-items="ViewBag.Categories"
                                        class="form-select">

                                    <option value="">
                                        -- Select Category --
                                    </option>

                                </select>

                                <span asp-validation-for="CategoryId"
                                      class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="SKU"
                                       class="form-label"></label>

                                <input asp-for="SKU"
                                       class="form-control"
                                       placeholder="PAN-500MG" />

                                <span asp-validation-for="SKU"
                                      class="text-danger small"></span>
                            </div>

                        </div>

                    </div>
                </div>

                <!-- PRICING -->
                <div class="main-card mb-4">

                    <div class="section-header">
                        <i class="bi bi-cash-coin me-2"></i>
                        Pricing & Stock
                    </div>

                    <div class="section-body">

                        <div class="row g-4">

                            <div class="col-md-4">
                                <label asp-for="Price"
                                       class="form-label"></label>

                                <div class="input-group">
                                    <span class="input-group-text">$</span>

                                    <input asp-for="Price"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           class="form-control"
                                           placeholder="0.00" />
                                </div>

                                <span asp-validation-for="Price"
                                      class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="DiscountPrice"
                                       class="form-label"></label>

                                <div class="input-group">
                                    <span class="input-group-text">$</span>

                                    <input asp-for="DiscountPrice"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           class="form-control"
                                           placeholder="Optional" />
                                </div>

                                <span asp-validation-for="DiscountPrice"
                                      class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="StockQuantity"
                                       class="form-label"></label>

                                <input asp-for="StockQuantity"
                                       type="number"
                                       min="0"
                                       class="form-control"
                                       placeholder="0" />

                                <span asp-validation-for="StockQuantity"
                                      class="text-danger small"></span>
                            </div>

                        </div>

                    </div>
                </div>

                <!-- IMAGE -->
                <div class="main-card mb-4">

                    <div class="section-header">
                        <i class="bi bi-image me-2"></i>
                        Product Image
                    </div>

                    <div class="section-body">

                        <input type="file"
                               name="imageFile"
                               id="imageFile"
                               class="form-control"
                               accept="image/*"
                               onchange="previewImage(event)" />

                        <div class="image-preview"
                             id="imagePreview">

                            <img id="previewImg"
                                 src="#"
                                 alt="Preview" />

                        </div>

                    </div>
                </div>

                <!-- STATUS -->
                <div class="main-card mb-4">

                    <div class="section-header">
                        <i class="bi bi-toggle-on me-2"></i>
                        Product Status
                    </div>

                    <div class="section-body">

                        <div class="status-box d-flex align-items-center justify-content-between">

                            <div>
                                <h6 class="fw-bold mb-1">
                                    Product Visibility
                                </h6>

                                <small class="text-muted">
                                    Inactive products will stay hidden from customers.
                                </small>
                            </div>

                            <div class="form-check form-switch custom-switch">
                                <input asp-for="IsActive"
                                       class="form-check-input"
                                       type="checkbox" />

                                <label asp-for="IsActive"
                                       class="form-check-label fw-semibold ms-2">
                                    Active
                                </label>
                            </div>

                        </div>

                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex gap-3">

                    <button type="submit"
                            class="btn btn-gradient">

                        <i class="bi bi-plus-circle me-2"></i>
                        Create Product

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-cancel">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">

            <div class="tips-card">

                <div class="tips-header">
                    <i class="bi bi-stars me-2"></i>
                    Smart Tips
                </div>

                <div class="p-4">

                    <div class="tip-item">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            Use a unique and memorable product name.
                        </div>
                    </div>

                    <div class="tip-item">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            Add high-quality images to increase engagement.
                        </div>
                    </div>

                    <div class="tip-item">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            Keep descriptions short, clean, and attractive.
                        </div>
                    </div>

                    <div class="tip-item mb-0">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            Set discount prices only during promotions.
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        function previewImage(event) {

            const file = event.target.files[0];

            if (!file) return;

            const reader = new FileReader();

            reader.onload = function (e) {

                document.getElementById('previewImg').src = e.target.result;

                document.getElementById('imagePreview').style.display = 'block';
            };

            reader.readAsDataURL(file);
        }

    </script>
}