@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = "Edit Product";
}

<style>

    body {
        background: #f4f7fb;
    }

    .edit-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-radius: 24px;
        padding: 28px;
        color: white;
        box-shadow: 0 12px 35px rgba(37,99,235,.22);
        position: relative;
        overflow: hidden;
    }

        .edit-header::before {
            content: "";
            position: absolute;
            width: 240px;
            height: 240px;
            background: rgba(255,255,255,.08);
            border-radius: 50%;
            top: -90px;
            right: -70px;
        }

    .glass-card {
        background: white;
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(0,0,0,.06);
    }

    .section-title {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        padding: 15px 22px;
        font-size: 17px;
        font-weight: 600;
    }

    .form-area {
        padding: 25px;
    }

    .form-label {
        font-weight: 600;
        color: #334155;
        margin-bottom: 8px;
    }

    .form-control,
    .form-select {
        border-radius: 16px;
        min-height: 50px;
        border: 1px solid #dbe2ea;
        transition: .25s;
    }

    textarea.form-control {
        min-height: 120px;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 .2rem rgba(99,102,241,.15);
    }

    .input-group-text {
        border-radius: 16px 0 0 16px;
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #dbe2ea;
        font-weight: 600;
    }

    .preview-box {
        background: #f8fafc;
        border: 2px dashed #c7d2fe;
        border-radius: 22px;
        padding: 25px;
        text-align: center;
    }

        .preview-box img {
            max-height: 180px;
            width: 100%;
            object-fit: contain;
            border-radius: 16px;
        }

    .meta-card {
        background: linear-gradient(180deg, #ffffff, #eef2ff);
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,.05);
        position: sticky;
        top: 20px;
    }

    .meta-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        padding: 16px 22px;
        font-weight: 700;
    }

    .meta-item {
        background: white;
        border-radius: 16px;
        padding: 14px 16px;
        margin-bottom: 14px;
    }

    .meta-label {
        color: #64748b;
        font-size: 14px;
    }

    .meta-value {
        color: #0f172a;
        font-weight: 600;
    }

    .btn-save {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: none;
        color: white;
        border-radius: 14px;
        padding: 13px 30px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-save:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(124,58,237,.22);
        }

    .btn-cancel {
        border-radius: 14px;
        padding: 13px 28px;
        font-weight: 600;
    }

    .status-box {
        background: linear-gradient(135deg, #ecfeff, #f0fdf4);
        border-radius: 18px;
        padding: 18px;
    }

    .status-switch .form-check-input {
        width: 3rem;
        height: 1.5rem;
    }

</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="edit-header mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div class="d-flex align-items-center gap-3">

                <a asp-action="Index"
                   class="btn btn-light rounded-circle shadow-sm">

                    <i class="bi bi-arrow-left"></i>

                </a>

                <div>

                    <h2 class="fw-bold mb-1">
                        Edit Product
                    </h2>

                    <div class="opacity-75">
                        Update your product information professionally
                    </div>

                </div>

            </div>

            <div class="text-end">

                <div class="small opacity-75">
                    Product ID
                </div>

                <div class="fw-bold fs-5">
                    #@Model.Id
                </div>

            </div>

        </div>

    </div>

    <div class="row g-4">

        <!-- FORM -->
        <div class="col-lg-8">

            <form asp-action="Edit"
                  asp-route-id="@Model.Id"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div asp-validation-summary="All"
                     class="alert alert-danger rounded-4 shadow-sm"
                     style="display:none">
                </div>

                <!-- BASIC INFO -->
                <div class="glass-card mb-4">

                    <div class="section-title">
                        <i class="bi bi-info-circle me-2"></i>
                        Basic Information
                    </div>

                    <div class="form-area">

                        <div class="mb-4">

                            <label asp-for="Name"
                                   class="form-label"></label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Enter product name" />

                            <span asp-validation-for="Name"
                                  class="text-danger small"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label"></label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      placeholder="Write product description..."></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger small"></span>

                        </div>

                        <div>

                            <label asp-for="CategoryId"
                                   class="form-label">
                                Category
                            </label>

                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="form-select">

                                <option value="">
                                    -- Select Category --
                                </option>

                            </select>

                            <span asp-validation-for="CategoryId"
                                  class="text-danger small"></span>

                        </div>

                    </div>

                </div>

                <!-- PRICING -->
                <div class="glass-card mb-4">

                    <div class="section-title">
                        <i class="bi bi-cash-stack me-2"></i>
                        Pricing & Stock
                    </div>

                    <div class="form-area">

                        <div class="row g-4">

                            <div class="col-md-4">

                                <label asp-for="Price"
                                       class="form-label"></label>

                                <div class="input-group">

                                    <span class="input-group-text">
                                        $
                                    </span>

                                    <input asp-for="Price"
                                           class="form-control"
                                           type="number"
                                           step="0.01"
                                           min="0" />

                                </div>

                                <span asp-validation-for="Price"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-md-4">

                                <label asp-for="DiscountPrice"
                                       class="form-label"></label>

                                <div class="input-group">

                                    <span class="input-group-text">
                                        $
                                    </span>

                                    <input asp-for="DiscountPrice"
                                           class="form-control"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           placeholder="Optional" />

                                </div>

                                <span asp-validation-for="DiscountPrice"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-md-4">

                                <label asp-for="StockQuantity"
                                       class="form-label"></label>

                                <input asp-for="StockQuantity"
                                       class="form-control"
                                       type="number"
                                       min="0" />

                                <span asp-validation-for="StockQuantity"
                                      class="text-danger small"></span>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- IMAGE -->
                <div class="glass-card mb-4">

                    <div class="section-title">
                        <i class="bi bi-image me-2"></i>
                        Product Image
                    </div>

                    <div class="form-area">

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="preview-box mb-4">

                                <p class="text-muted mb-3">
                                    Current Image
                                </p>

                                <img src="@Model.ImageUrl"
                                     alt="@Model.Name" />

                            </div>
                        }

                        <label class="form-label fw-semibold">

                            @(string.IsNullOrEmpty(Model.ImageUrl)
                                ? "Upload New Image"
                                : "Replace Current Image")

                        </label>

                        <input type="file"
                               name="imageFile"
                               class="form-control"
                               accept="image/*"
                               onchange="previewImage(event)" />

                        <div id="imagePreview"
                             class="preview-box mt-4"
                             style="display:none;">

                            <p class="text-muted mb-3">
                                New Preview
                            </p>

                            <img id="previewImg"
                                 src="#"
                                 alt="Preview" />

                        </div>

                    </div>

                </div>

                <!-- STATUS -->
                <div class="glass-card mb-4">

                    <div class="section-title">
                        <i class="bi bi-toggle-on me-2"></i>
                        Product Status
                    </div>

                    <div class="form-area">

                        <div class="status-box d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="fw-bold mb-1">
                                    Product Visibility
                                </h6>

                                <small class="text-muted">
                                    Inactive products won't appear in the storefront.
                                </small>

                            </div>

                            <div class="form-check form-switch status-switch">

                                <input asp-for="IsActive"
                                       class="form-check-input"
                                       type="checkbox"
                                       role="switch" />

                                <label asp-for="IsActive"
                                       class="form-check-label fw-semibold ms-2">

                                    Active

                                </label>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- ACTIONS -->
                <div class="d-flex flex-wrap gap-3">

                    <button type="submit"
                            class="btn btn-save">

                        <i class="bi bi-floppy me-2"></i>
                        Save Changes

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-cancel">

                        <i class="bi bi-x-circle me-2"></i>
                        Cancel

                    </a>

                </div>

            </form>

        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">

            <div class="meta-card">

                <div class="meta-header">

                    <i class="bi bi-info-circle me-2"></i>
                    Product Insights

                </div>

                <div class="p-4">

                    <div class="meta-item">

                        <div class="meta-label mb-1">
                            Created At
                        </div>

                        <div class="meta-value">
                            @Model.AddedAt
                        </div>

                    </div>

                    @if (!string.IsNullOrEmpty(Model.UpdatedAt))
                    {
                        <div class="meta-item">

                            <div class="meta-label mb-1">
                                Last Updated
                            </div>

                            <div class="meta-value">
                                @Model.UpdatedAt
                            </div>

                        </div>
                    }

                    <div class="meta-item mb-0">

                        <div class="meta-label mb-1">
                            Reviews Count
                        </div>

                        <div class="meta-value">
                            @Model.Reviews.Count Review(s)
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        function previewImage(event) {

            const file = event.target.files[0];

            if (!file) return;

            const reader = new FileReader();

            reader.onload = e => {

                document.getElementById('previewImg').src = e.target.result;

                document.getElementById('imagePreview').style.display = 'block';
            };

            reader.readAsDataURL(file);
        }

        document.addEventListener('DOMContentLoaded', () => {

            const vs = document.querySelector('[data-valmsg-summary]');

            if (vs && vs.querySelectorAll('li').length > 0)
                vs.style.display = 'block';
        });

    </script>
}