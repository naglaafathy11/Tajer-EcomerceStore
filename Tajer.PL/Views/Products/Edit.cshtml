@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = "Edit Product";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="fw-semibold mb-0">Edit Product</h2>
    <span class="text-muted small ms-1">#@Model.Id</span>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:none"></div>

            @* Basic Info *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-medium py-3">Basic Information</div>
                <div class="card-body">

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-medium"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label fw-medium">Category</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">— Select category —</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                </div>
            </div>

            @* Pricing & Stock *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-medium py-3">Pricing & Stock</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="Price" class="form-label fw-medium"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="DiscountPrice" class="form-label fw-medium"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="DiscountPrice" class="form-control" type="number" step="0.01" min="0" placeholder="Optional" />
                            </div>
                            <span asp-validation-for="DiscountPrice" class="text-danger small"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="StockQuantity" class="form-label fw-medium"></label>
                            <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* Image *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white fw-medium py-3">Product Image</div>
                <div class="card-body">

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3">
                            <p class="small text-muted mb-1">Current image:</p>
                            <img src="@Model.ImageUrl" alt="@Model.Name"
                                 class="rounded border" style="max-height:160px;object-fit:contain;" />
                        </div>
                    }

                    <label class="form-label fw-medium">
                        @(string.IsNullOrEmpty(Model.ImageUrl) ? "Upload Image" : "Replace Image")
                    </label>
                    <input type="file" name="imageFile" class="form-control"
                           accept="image/*" onchange="previewImage(event)" />
                    <div id="imagePreview" class="mt-3" style="display:none;">
                        <img id="previewImg" src="#" alt="New preview"
                             class="rounded border" style="max-height:160px;object-fit:contain;" />
                    </div>

                    @* Keep old URL if no new image uploaded *@
                    <input type="hidden" asp-for="ImageUrl" />

                </div>
            </div>

            @* Status *@
            <div class="card shadow-sm mb-4">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="form-check form-switch mb-0">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label fw-medium">Active</label>
                    </div>
                    <small class="text-muted">Inactive products won't appear in the storefront.</small>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-floppy me-1"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
            </div>

        </form>
    </div>

    @* Sidebar meta *@
    <div class="col-lg-4">
        <div class="card border-0 bg-light">
            <div class="card-body small text-muted">
                <h6 class="fw-semibold text-dark mb-3"><i class="bi bi-info-circle me-2"></i>Product Info</h6>
                <div class="mb-2 d-flex justify-content-between">
                    <span>Created</span>
                    <span class="text-dark">@Model.AddedAt</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.UpdatedAt))
                {
                    <div class="mb-2 d-flex justify-content-between">
                        <span>Last updated</span>
                        <span class="text-dark">@Model.UpdatedAt</span>
                    </div>
                }
                <div class="d-flex justify-content-between">
                    <span>Reviews</span>
                    <span class="text-dark">@Model.Reviews.Count</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('imagePreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const vs = document.querySelector('[data-valmsg-summary]');
            if (vs && vs.querySelectorAll('li').length > 0)
                vs.style.display = 'block';
        });
    </script>
}
