@model IEnumerable<Tajer.BL.DTO.ProductDTO>

@{
    ViewData["Title"] = "Products";
}

<style>

    body {
        background: #f4f7fb;
    }

    .page-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-radius: 26px;
        padding: 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(37,99,235,.22);
    }

        .page-header::before {
            content: "";
            position: absolute;
            width: 250px;
            height: 250px;
            border-radius: 50%;
            background: rgba(255,255,255,.08);
            top: -100px;
            right: -80px;
        }

    .btn-add {
        background: white;
        color: #2563eb;
        border: none;
        border-radius: 14px;
        padding: 12px 24px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255,255,255,.18);
            color: #2563eb;
        }

    .glass-card {
        background: white;
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0,0,0,.06);
    }

    .table thead {
        background: linear-gradient(135deg, #eff6ff, #f5f3ff);
    }

        .table thead th {
            border: none;
            padding: 18px 16px;
            color: #475569;
            font-weight: 700;
            font-size: 14px;
            white-space: nowrap;
        }

    .table tbody td {
        padding: 18px 16px;
        vertical-align: middle;
        border-color: #eef2f7;
    }

    .table tbody tr {
        transition: .25s;
    }

        .table tbody tr:hover {
            background: #f8fafc;
            transform: scale(1.002);
        }

    .product-img {
        width: 58px;
        height: 58px;
        object-fit: cover;
        border-radius: 16px;
        border: 2px solid #fff;
        box-shadow: 0 4px 10px rgba(0,0,0,.08);
    }

    .empty-img {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        background: #eef2f7;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 22px;
    }

    .product-name {
        font-weight: 700;
        color: #0f172a;
    }

    .category-badge {
        background: rgba(99,102,241,.1);
        color: #4f46e5;
        border-radius: 30px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .status-badge {
        border-radius: 30px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .price-text {
        font-weight: 700;
        color: #0f172a;
    }

    .discount-text {
        font-weight: 700;
        color: #dc2626;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .25s;
    }

        .action-btn:hover {
            transform: translateY(-2px);
        }

    .stats-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(180px,1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    .stat-card {
        background: white;
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 8px 25px rgba(0,0,0,.05);
    }

    .stat-icon {
        width: 55px;
        height: 55px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
        font-size: 22px;
    }

    .empty-state {
        padding: 70px 20px;
        text-align: center;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 70px;
            margin-bottom: 20px;
            display: block;
        }

</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="page-header mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <h2 class="fw-bold mb-2">
                    Products Management
                </h2>

                <div class="opacity-75">
                    Manage your products, pricing, stock and visibility
                </div>

            </div>

            <a asp-action="Create"
               class="btn btn-add">

                <i class="bi bi-plus-circle me-2"></i>
                Add Product

            </a>

        </div>

    </div>

    <!-- STATS -->
    <div class="stats-bar">

        <div class="stat-card">

            <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                <i class="bi bi-box-seam"></i>
            </div>

            <div class="text-muted small mb-1">
                Total Products
            </div>

            <div class="fw-bold fs-3">
                @Model.Count()
            </div>

        </div>

        <div class="stat-card">

            <div class="stat-icon bg-success bg-opacity-10 text-success">
                <i class="bi bi-check-circle"></i>
            </div>

            <div class="text-muted small mb-1">
                Active Products
            </div>

            <div class="fw-bold fs-3">
                @Model.Count(p => p.IsActive)
            </div>

        </div>

        <div class="stat-card">

            <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                <i class="bi bi-exclamation-circle"></i>
            </div>

            <div class="text-muted small mb-1">
                Out Of Stock
            </div>

            <div class="fw-bold fs-3">
                @Model.Count(p => p.StockQuantity == 0)
            </div>

        </div>

        <div class="stat-card">

            <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                <i class="bi bi-percent"></i>
            </div>

            <div class="text-muted small mb-1">
                Discounted
            </div>

            <div class="fw-bold fs-3">
                @Model.Count(p => p.DiscountPrice.HasValue)
            </div>

        </div>

    </div>

    <!-- ALERTS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 alert-dismissible fade show">

            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>

        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 alert-dismissible fade show">

            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>

        </div>
    }

    <!-- TABLE -->
    <div class="glass-card">

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>

                    <tr>

                        <th>#</th>
                        <th>Image</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Discount</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Added</th>
                        <th class="text-center">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>

                            <td colspan="10">

                                <div class="empty-state">

                                    <i class="bi bi-box-seam"></i>

                                    <h5 class="fw-bold text-dark">
                                        No Products Found
                                    </h5>

                                    <p class="mb-0">
                                        Start adding products to manage your inventory.
                                    </p>

                                </div>

                            </td>

                        </tr>
                    }

                    @foreach (var p in Model)
                    {
                        <tr>

                            <td class="text-muted small fw-semibold">
                                #@p.Id
                            </td>

                            <td>

                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl"
                                         alt="@p.Name"
                                         class="product-img" />
                                }
                                else
                                {
                                    <div class="empty-img">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }

                            </td>

                            <td>

                                <div class="product-name">
                                    @p.Name
                                </div>

                            </td>

                            <td>

                                <span class="category-badge">
                                    @p.CategoryName
                                </span>

                            </td>

                            <td>

                                <span class="price-text">
                                    @p.Price.ToString("C")
                                </span>

                            </td>

                            <td>

                                @if (p.DiscountPrice.HasValue)
                                {
                                    <span class="discount-text">
                                        @p.DiscountPrice.Value.ToString("C")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        —
                                    </span>
                                }

                            </td>

                            <td>

                                @if (p.StockQuantity == 0)
                                {
                                    <span class="badge bg-danger status-badge">
                                        Out Of Stock
                                    </span>
                                }
                                else if (p.StockQuantity < 10)
                                {
                                    <span class="badge bg-warning text-dark status-badge">
                                        @p.StockQuantity Low
                                    </span>
                                }
                                else
                                {
                                    <span class="fw-semibold text-success">
                                        @p.StockQuantity
                                    </span>
                                }

                            </td>

                            <td>

                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success status-badge">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary status-badge">
                                        Inactive
                                    </span>
                                }

                            </td>

                            <td class="text-muted small">
                                @p.AddedAt
                            </td>

                            <td>

                                <div class="d-flex justify-content-center gap-2">

                                    <!-- DETAILS -->
                                    <a asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="btn btn-outline-secondary action-btn"
                                       title="Details">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <!-- EDIT -->
                                    <a asp-action="Edit"
                                       asp-route-id="@p.Id"
                                       class="btn btn-outline-primary action-btn"
                                       title="Edit">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <!-- TOGGLE -->
                                    <form asp-action="Toggle"
                                          asp-route-id="@p.Id"
                                          method="post"
                                          class="d-inline">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn @(p.IsActive
                                                                                                    ? "btn-outline-warning"
                                                                                                    : "btn-outline-success")
                                            action-btn"
                                                title="@(p.IsActive
                                                                                                    ? "Deactivate"
                                                                                                    : "Activate")">

                                            <i class="bi @(p.IsActive
                                                                                               ? "bi-toggle-on"
                                                                                               : "bi-toggle-off")"></i>

                                        </button>

                                    </form>

                                    <!-- DELETE -->
                                    <a asp-action="Delete"
                                       asp-route-id="@p.Id"
                                       class="btn btn-outline-danger action-btn"
                                       title="Delete">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>