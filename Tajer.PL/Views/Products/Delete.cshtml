@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = "Delete Product";
}

<style>

    body {
        background: #f4f7fb;
    }

    .delete-header {
        background: linear-gradient(135deg, #dc2626, #ef4444);
        border-radius: 24px;
        padding: 28px;
        color: white;
        box-shadow: 0 12px 35px rgba(220,38,38,.25);
        position: relative;
        overflow: hidden;
    }

        .delete-header::before {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            background: rgba(255,255,255,.08);
            border-radius: 50%;
            top: -80px;
            right: -70px;
        }

    .danger-card {
        background: white;
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    .danger-top {
        background: linear-gradient(135deg, #fee2e2, #fef2f2);
        padding: 24px;
        border-bottom: 1px solid #fecaca;
    }

    .warning-icon {
        width: 75px;
        height: 75px;
        border-radius: 50%;
        background: rgba(239,68,68,.12);
        color: #dc2626;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        flex-shrink: 0;
    }

    .product-box {
        background: #f8fafc;
        border-radius: 22px;
        padding: 22px;
        transition: .3s;
    }

        .product-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,.05);
        }

    .product-image {
        width: 90px;
        height: 90px;
        border-radius: 18px;
        object-fit: cover;
        border: 2px solid #fff;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .empty-image {
        width: 90px;
        height: 90px;
        border-radius: 18px;
        background: #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 32px;
    }

    .info-item {
        background: white;
        border-radius: 16px;
        padding: 15px 18px;
        margin-bottom: 14px;
        border: 1px solid #eef2f7;
    }

    .info-label {
        color: #64748b;
        font-size: 14px;
    }

    .info-value {
        font-weight: 600;
        color: #1e293b;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc2626, #ef4444);
        border: none;
        color: white;
        border-radius: 14px;
        padding: 13px 28px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-delete:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(239,68,68,.25);
        }

    .btn-cancel {
        border-radius: 14px;
        padding: 13px 28px;
        font-weight: 600;
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 13px;
    }

    .danger-note {
        background: linear-gradient(135deg, #fff1f2, #fef2f2);
        border: 1px solid #fecdd3;
        border-radius: 18px;
        padding: 18px;
        color: #991b1b;
    }

</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="delete-header mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div class="d-flex align-items-center gap-3">

                <a asp-action="Index"
                   class="btn btn-light rounded-circle shadow-sm">
                    <i class="bi bi-arrow-left"></i>
                </a>

                <div>
                    <h2 class="fw-bold mb-1">
                        Delete Product
                    </h2>

                    <div class="opacity-75">
                        Permanently remove this product from the system
                    </div>
                </div>

            </div>

            <div class="text-end">
                <div class="small opacity-75">
                    Product ID
                </div>

                <div class="fw-bold fs-5">
                    #@Model.Id
                </div>
            </div>

        </div>

    </div>

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="danger-card">

                <!-- WARNING -->
                <div class="danger-top">

                    <div class="d-flex gap-4 align-items-start">

                        <div class="warning-icon">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>

                        <div>

                            <h4 class="fw-bold text-danger mb-2">
                                Are you absolutely sure?
                            </h4>

                            <p class="mb-0 text-danger-emphasis">
                                This action cannot be undone.
                                The product and all associated data
                                will be permanently deleted from the system.
                            </p>

                        </div>

                    </div>

                </div>

                <!-- BODY -->
                <div class="p-4">

                    <!-- PRODUCT CARD -->
                    <div class="product-box mb-4">

                        <div class="d-flex gap-4 align-items-center flex-wrap">

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl"
                                     alt="@Model.Name"
                                     class="product-image" />
                            }
                            else
                            {
                                <div class="empty-image">
                                    <i class="bi bi-image"></i>
                                </div>
                            }

                            <div class="flex-grow-1">

                                <h4 class="fw-bold mb-1">
                                    @Model.Name
                                </h4>

                                <div class="text-muted mb-3">
                                    @Model.CategoryName
                                </div>

                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success status-badge">
                                        <i class="bi bi-check-circle me-1"></i>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary status-badge">
                                        <i class="bi bi-pause-circle me-1"></i>
                                        Inactive
                                    </span>
                                }

                            </div>

                        </div>

                    </div>

                    <!-- PRODUCT INFO -->
                    <div class="row">

                        <div class="col-md-6">

                            <div class="info-item">
                                <div class="info-label mb-1">
                                    <i class="bi bi-cash-stack me-1"></i>
                                    Product Price
                                </div>

                                <div class="info-value">
                                    @Model.Price.ToString("C")
                                </div>
                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="info-item">
                                <div class="info-label mb-1">
                                    <i class="bi bi-box-seam me-1"></i>
                                    Stock Quantity
                                </div>

                                <div class="info-value">
                                    @Model.StockQuantity unit(s)
                                </div>
                            </div>

                        </div>

                    </div>

                    <div class="info-item">

                        <div class="info-label mb-1">
                            <i class="bi bi-calendar-event me-1"></i>
                            Created At
                        </div>

                        <div class="info-value">
                            @Model.AddedAt
                        </div>

                    </div>

                    <!-- DANGER NOTE -->
                    <div class="danger-note mt-4">

                        <div class="d-flex gap-2 align-items-start">

                            <i class="bi bi-shield-exclamation fs-5"></i>

                            <div>
                                <strong>Important:</strong>
                                Deleting this product will remove
                                all related records and cannot be recovered later.
                            </div>

                        </div>

                    </div>

                    <!-- ACTIONS -->
                    <div class="d-flex flex-wrap gap-3 mt-4">

                        <form asp-action="Delete"
                              asp-route-id="@Model.Id"
                              method="post">

                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn btn-delete">

                                <i class="bi bi-trash3 me-2"></i>
                                Yes, Delete Product

                            </button>

                        </form>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary btn-cancel">

                            <i class="bi bi-x-circle me-2"></i>
                            Cancel

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>