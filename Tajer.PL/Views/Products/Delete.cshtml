@model Tajer.BL.DTO.ProductDTO
@{
    ViewData["Title"] = "Delete Product";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="fw-semibold mb-0">Delete Product</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="alert alert-danger d-flex gap-3 align-items-start mb-4">
            <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0 mt-1"></i>
            <div>
                <strong>This action cannot be undone.</strong><br />
                <span class="small">The product and all associated data will be permanently removed.</span>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex gap-3 align-items-center mb-3">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name"
                             class="rounded border" style="width:64px;height:64px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded bg-light border d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:64px;height:64px;">
                            <i class="bi bi-image text-muted fs-4"></i>
                        </div>
                    }
                    <div>
                        <div class="fw-semibold fs-5">@Model.Name</div>
                        <div class="text-muted small">@Model.CategoryName</div>
                    </div>
                </div>

                <dl class="row small mb-0">
                    <dt class="col-5 text-muted fw-normal">Price</dt>
                    <dd class="col-7">@Model.Price.ToString("C")</dd>

                    <dt class="col-5 text-muted fw-normal">Stock</dt>
                    <dd class="col-7">@Model.StockQuantity units</dd>

                    <dt class="col-5 text-muted fw-normal">Status</dt>
                    <dd class="col-7">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-5 text-muted fw-normal">Created</dt>
                    <dd class="col-7">@Model.AddedAt</dd>
                </dl>
            </div>
        </div>

        <div class="d-flex gap-2">
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i> Yes, Delete
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>

    </div>
</div>
