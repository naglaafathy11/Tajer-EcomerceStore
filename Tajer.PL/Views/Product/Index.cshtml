@model IEnumerable<ProductDTO>

<h2 class="my-3">Products</h2>

<a class="btn btn-primary my-3" asp-controller="Product"  asp-action="Add"> Add Product</a>

@if(Model.Any())
{
    <table class="table table-striped table-hover mt-2">
        <thead  claa="text-center">
         <tr>
             <th>@Html.DisplayNameFor(p=>p.Name)</th>
             <th>@Html.DisplayNameFor(p => p.Price)</th>

             <th>@Html.DisplayNameFor(p => p.StockQuantity)</th>

             <th>@Html.DisplayNameFor(p => p.IsActive)</th>
             <th>@Html.DisplayNameFor(p => p.AddedAt)</th>


              <th>Details</th>
                <th>Update</th>
                <th>Delete</th>


         </tr>
        </thead>
        <tbody class="text-center">
            @foreach (var product in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(p => product.Name)</td>
                    <td>@Html.DisplayFor(p => product.Price)</td>
                    <td>@Html.DisplayFor(p => product.StockQuantity)</td>
                    <td>@Html.DisplayFor(p => product.IsActive)</td>
                    <td>@Html.DisplayFor(p => product.AddedAt)</td>


                    <td>
                        <a class="btn btn-primary" asp-action="Details" asp-route-id="@product.Id">
                            <i class="fas fa-eye"></i> Details
                        </a>
                    </td>
                    <td>
                        <a class="btn btn-success" asp-action="Edit" asp-route-id="@product.Id">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                    </td>
                    <td>
                        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@product.Id">
                            <i class="fas fa-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info mt-2">
        <h2> No Product Found </h2>

    </div>
}