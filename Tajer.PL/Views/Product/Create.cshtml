@model Tajer.BL.DTO.ProductDTO

@{
    ViewData["Title"] = "Create Product";
}

<div class="container mt-5">

    <div class="card shadow-lg">

        <div class="card-header bg-dark text-white">
            <h4>Create Product</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="All" class="text-danger"></div>

                <!-- Name -->
                <div class="mb-3">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <!-- CategoryId -->
                <div class="mb-3">
                    <label asp-for="CategoryId">Category Id</label>
                    <input asp-for="CategoryId" class="form-control" />
                </div>

                <!-- CategoryName (optional display only) -->
                <div class="mb-3">
                    <label>Category Name</label>
                    <input asp-for="CategoryName" class="form-control" readonly />
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                </div>

                <!-- Price -->
                <div class="mb-3">
                    <label asp-for="Price"></label>
                    <input asp-for="Price" class="form-control" />
                </div>

                <!-- Discount -->
                <div class="mb-3">
                    <label asp-for="DiscountPrice"></label>
                    <input asp-for="DiscountPrice" class="form-control" />
                </div>

                <!-- Stock -->
                <div class="mb-3">
                    <label asp-for="StockQuantity"></label>
                    <input asp-for="StockQuantity" class="form-control" />
                </div>

                <!-- IsActive -->
                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>

                <!-- AddedAt (hidden - system value) -->
                <input type="hidden" asp-for="AddedAt" />

                <button type="submit" class="btn btn-success">
                    Create
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>