@model Tajer.BL.DTO.CategoryDTO

@{
    ViewData["Title"] = "Edit Category";
}

<style>

    body {
        background: #f4f7fb;
    }

    .page-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-radius: 30px;
        padding: 35px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(37,99,235,.18);
    }

        .page-header::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(255,255,255,.08);
            top: -120px;
            right: -100px;
        }

        .page-header::after {
            content: "";
            position: absolute;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,.05);
            bottom: -80px;
            left: -60px;
        }

    .glass-card {
        background: rgba(255,255,255,.95);
        border-radius: 28px;
        border: none;
        overflow: hidden;
        backdrop-filter: blur(12px);
        box-shadow: 0 12px 35px rgba(15,23,42,.08);
    }

    .section-title {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        padding: 18px 24px;
        border-bottom: 1px solid #edf2f7;
        font-weight: 700;
        font-size: 16px;
        color: #1e293b;
    }

    .form-control,
    .form-select {
        border-radius: 16px;
        padding: 14px 16px;
        border: 1px solid #dbe4f0;
        transition: .3s;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 .25rem rgba(124,58,237,.12) !important;
        }

    textarea.form-control {
        resize: none;
    }

    .form-label {
        color: #334155;
        margin-bottom: 8px;
    }

    .custom-upload {
        border: 2px dashed #cbd5e1;
        border-radius: 24px;
        padding: 35px;
        text-align: center;
        background: #f8fafc;
        transition: .3s;
    }

        .custom-upload:hover {
            border-color: #7c3aed;
            background: #f5f3ff;
        }

    .current-image {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 24px;
        border: 5px solid white;
        box-shadow: 0 12px 25px rgba(0,0,0,.08);
    }

    .preview-image {
        max-height: 180px;
        border-radius: 22px;
        border: 4px solid white;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
    }

    .switch-box {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        border-radius: 22px;
        padding: 22px;
    }

    .form-check-input {
        width: 3rem;
        height: 1.5rem;
    }

        .form-check-input:checked {
            background-color: #7c3aed;
            border-color: #7c3aed;
        }

    .btn-save {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: none;
        color: white;
        border-radius: 16px;
        padding: 14px 32px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-save:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 12px 22px rgba(124,58,237,.2);
        }

    .btn-cancel {
        border-radius: 16px;
        padding: 14px 28px;
        font-weight: 600;
    }

    .side-card {
        background: white;
        border-radius: 26px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
        border: none;
    }

    .side-stat {
        background: #f8fafc;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 16px;
    }

    .side-stat-label {
        color: #64748b;
        font-size: 13px;
        margin-bottom: 5px;
    }

    .side-stat-value {
        font-size: 22px;
        font-weight: 700;
        color: #0f172a;
    }

</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="page-header mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div class="d-flex align-items-center gap-3">

                <a asp-action="Index"
                   class="btn btn-light rounded-circle shadow-sm">

                    <i class="bi bi-arrow-left"></i>

                </a>

                <div>

                    <h2 class="fw-bold mb-1">
                        Edit Category
                    </h2>

                    <div class="opacity-75">
                        Update category information and appearance
                    </div>

                </div>

            </div>

            <span class="badge bg-light text-dark px-3 py-2 rounded-pill fw-semibold">

                <i class="bi bi-hash me-1"></i>
                ID : @Model.Id

            </span>

        </div>

    </div>

    <div class="row g-4">

        <!-- FORM -->
        <div class="col-lg-8">

            <form asp-action="Edit"
                  asp-route-id="@Model.Id"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="All"
                     class="alert alert-danger rounded-4 py-3"
                     style="display:none">
                </div>

                <!-- CATEGORY INFO -->
                <div class="glass-card mb-4">

                    <div class="section-title">

                        <i class="bi bi-folder2-open me-2"></i>
                        Category Information

                    </div>

                    <div class="p-4">

                        <!-- NAME -->
                        <div class="mb-4">

                            <label asp-for="Name"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Enter category name" />

                            <span asp-validation-for="Name"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- DESCRIPTION -->
                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label fw-semibold">
                            </label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Write category description..."></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- DISPLAY ORDER -->
                        <div>

                            <label asp-for="DisplayOrder"
                                   class="form-label fw-semibold">

                                Display Order

                            </label>

                            <input asp-for="DisplayOrder"
                                   class="form-control"
                                   type="number"
                                   min="0"
                                   placeholder="0" />

                            <div class="form-text mt-2">
                                Lower number means this category appears first.
                            </div>

                        </div>

                    </div>

                </div>

                <!-- IMAGE -->
                <div class="glass-card mb-4">

                    <div class="section-title">

                        <i class="bi bi-image me-2"></i>
                        Category Image

                    </div>

                    <div class="p-4">

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-4 text-center">

                                <div class="small text-muted mb-3">
                                    Current Image
                                </div>

                                <img src="@Model.ImageUrl"
                                     alt="@Model.Name"
                                     class="current-image" />

                            </div>
                        }

                        <div class="custom-upload">

                            <i class="bi bi-cloud-arrow-up fs-1 text-primary mb-3 d-block"></i>

                            <h5 class="fw-bold mb-2">

                                @(string.IsNullOrEmpty(Model.ImageUrl)
                                    ? "Upload Category Image"
                                    : "Replace Current Image")

                            </h5>

                            <div class="text-muted mb-4">
                                Drag & drop image here or choose from your device
                            </div>

                            <input type="file"
                                   name="imageFile"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(event)" />

                            <div id="imagePreview"
                                 class="mt-4"
                                 style="display:none;">

                                <img id="previewImg"
                                     src="#"
                                     alt="Preview"
                                     class="preview-image" />

                            </div>

                        </div>

                        <input type="hidden" asp-for="ImageUrl" />

                    </div>

                </div>

                <!-- STATUS -->
                <div class="glass-card mb-4">

                    <div class="p-4">

                        <div class="switch-box d-flex justify-content-between align-items-center flex-wrap gap-3">

                            <div>

                                <h5 class="fw-bold mb-1">
                                    Category Visibility
                                </h5>

                                <div class="text-muted">
                                    Inactive categories won't appear in the storefront.
                                </div>

                            </div>

                            <div class="form-check form-switch m-0">

                                <input asp-for="IsActive"
                                       class="form-check-input"
                                       type="checkbox"
                                       role="switch" />

                                <label asp-for="IsActive"
                                       class="form-check-label fw-semibold ms-2">

                                    Active

                                </label>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- ACTIONS -->
                <div class="d-flex flex-wrap gap-3">

                    <button type="submit"
                            class="btn btn-save">

                        <i class="bi bi-floppy-fill me-2"></i>
                        Save Changes

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-cancel">

                        <i class="bi bi-x-circle me-2"></i>
                        Cancel

                    </a>

                </div>

            </form>

        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">

            <div class="side-card">

                <h5 class="fw-bold mb-4">

                    <i class="bi bi-info-circle me-2 text-primary"></i>
                    Category Insights

                </h5>

                <div class="side-stat">

                    <div class="side-stat-label">
                        Category ID
                    </div>

                    <div class="side-stat-value">
                        #@Model.Id
                    </div>

                </div>

                <div class="side-stat">

                    <div class="side-stat-label">
                        Current Status
                    </div>

                    <div class="side-stat-value fs-4">

                        @(Model.IsActive ? "Active" : "Inactive")

                    </div>

                </div>

                <div class="side-stat mb-0">

                    <div class="side-stat-label">
                        Display Order
                    </div>

                    <div class="side-stat-value">
                        @Model.DisplayOrder
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        function previewImage(event) {

            const file = event.target.files[0];

            if (!file) return;

            const reader = new FileReader();

            reader.onload = e => {

                document.getElementById('previewImg').src = e.target.result;

                document.getElementById('imagePreview').style.display = 'block';

            };

            reader.readAsDataURL(file);

        }

        document.addEventListener('DOMContentLoaded', () => {

            const vs = document.querySelector('[data-valmsg-summary]');

            if (vs && vs.querySelectorAll('li').length > 0)
                vs.style.display = 'block';

        });

    </script>

}