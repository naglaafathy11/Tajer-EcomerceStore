@model Tajer.BL.DTO.CategoryDTO

@{
    ViewData["Title"] = Model.Name;
}

<style>

    body {
        background: #f4f7fb;
    }

    .details-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-radius: 28px;
        padding: 32px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(37,99,235,.22);
    }

        .details-header::before {
            content: "";
            position: absolute;
            width: 250px;
            height: 250px;
            border-radius: 50%;
            background: rgba(255,255,255,.08);
            top: -100px;
            right: -80px;
        }

    .glass-card {
        background: white;
        border-radius: 26px;
        border: none;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
    }

    .image-section {
        background: linear-gradient(180deg, #ffffff, #eef2ff);
        min-height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
        position: relative;
    }

    .category-image {
        max-width: 100%;
        max-height: 320px;
        object-fit: contain;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .empty-image {
        text-align: center;
        color: #94a3b8;
    }

        .empty-image i {
            font-size: 80px;
            margin-bottom: 18px;
            display: block;
        }

    .details-body {
        padding: 32px;
    }

    .category-title {
        font-size: 34px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .category-description {
        color: #64748b;
        font-size: 16px;
        line-height: 1.8;
    }

    .status-badge {
        padding: 10px 18px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 700;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .info-card {
        background: #f8fafc;
        border-radius: 22px;
        padding: 24px;
        transition: .3s;
        border: 1px solid #eef2f7;
    }

        .info-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,.06);
        }

    .info-icon {
        width: 55px;
        height: 55px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        font-size: 22px;
    }

    .info-label {
        color: #64748b;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .info-value {
        color: #0f172a;
        font-size: 22px;
        font-weight: 700;
    }

    .action-section {
        margin-top: 30px;
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
    }

    .btn-edit {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: none;
        color: white;
        border-radius: 14px;
        padding: 13px 28px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-edit:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(124,58,237,.22);
        }

    .btn-toggle,
    .btn-delete {
        border-radius: 14px;
        padding: 13px 26px;
        font-weight: 600;
    }

</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="details-header mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div class="d-flex align-items-center gap-3">

                <a asp-action="Index"
                   class="btn btn-light rounded-circle shadow-sm">

                    <i class="bi bi-arrow-left"></i>

                </a>

                <div>

                    <h2 class="fw-bold mb-1">
                        Category Details
                    </h2>

                    <div class="opacity-75">
                        Full information about this category
                    </div>

                </div>

            </div>

            @if (Model.IsActive)
            {
                <span class="badge bg-success status-badge">
                    <i class="bi bi-check-circle-fill me-1"></i>
                    Active
                </span>
            }
            else
            {
                <span class="badge bg-danger status-badge">
                    <i class="bi bi-x-circle-fill me-1"></i>
                    Inactive
                </span>
            }

        </div>

    </div>

    <!-- MAIN CARD -->
    <div class="glass-card">

        <div class="row g-0">

            <!-- IMAGE -->
            <div class="col-lg-4">

                <div class="image-section">

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             alt="@Model.Name"
                             class="category-image" />
                    }
                    else
                    {
                        <div class="empty-image">

                            <i class="bi bi-folder2-open"></i>

                            <h5 class="fw-bold">
                                No Image
                            </h5>

                            <div>
                                This category doesn't have an image yet
                            </div>

                        </div>
                    }

                </div>

            </div>

            <!-- DETAILS -->
            <div class="col-lg-8">

                <div class="details-body">

                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                        <div>

                            <div class="category-title">
                                @Model.Name
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <div class="category-description">

                                    @Model.Description

                                </div>
                            }
                            else
                            {
                                <div class="category-description">
                                    No description available for this category.
                                </div>
                            }

                        </div>

                    </div>

                    <!-- INFO -->
                    <div class="info-grid">

                        <!-- DISPLAY ORDER -->
                        <div class="info-card">

                            <div class="info-icon bg-primary bg-opacity-10 text-primary">

                                <i class="bi bi-sort-numeric-down"></i>

                            </div>

                            <div class="info-label">
                                Display Order
                            </div>

                            <div class="info-value">
                                @Model.DisplayOrder
                            </div>

                        </div>

                        <!-- STATUS -->
                        <div class="info-card">

                            <div class="info-icon @(Model.IsActive
                                                                 ? "bg-success bg-opacity-10 text-success"
                                                                 : "bg-danger bg-opacity-10 text-danger")">

                                <i class="bi @(Model.IsActive
                                                                       ? "bi-check-circle"
                                                                       : "bi-x-circle")"></i>

                            </div>

                            <div class="info-label">
                                Status
                            </div>

                            <div class="info-value fs-4">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </div>

                        </div>

                    </div>

                    <!-- ACTIONS -->
                    <div class="action-section">

                        <!-- EDIT -->
                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-edit">

                            <i class="bi bi-pencil-square me-2"></i>
                            Edit Category

                        </a>

                        <!-- TOGGLE -->
                        <form asp-action="Toggle"
                              asp-route-id="@Model.Id"
                              method="post"
                              class="d-inline">

                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn @(Model.IsActive
                                                                            ? "btn-outline-warning"
                                                                            : "btn-outline-success")
                                btn-toggle">

                                <i class="bi @(Model.IsActive
                                                                       ? "bi-toggle-on"
                                                                       : "bi-toggle-off") me-2"></i>

                                @(Model.IsActive
                                    ? "Deactivate"
                                    : "Activate")

                            </button>

                        </form>

                        <!-- DELETE -->
                        <a asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-danger btn-delete ms-lg-auto">

                            <i class="bi bi-trash3 me-2"></i>
                            Delete Category

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>